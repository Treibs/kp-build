  "debates": [
    {
      "id": "d1",
      "positions": [
        "Long-context wins on accuracy when resourced",
        "Retrieval/explicit memory wins on cost and some query types, and long context is unreliable",
        "Hybrid routing is the practical resolution"
      ]
    },
    {
      "id": "d2",
      "positions": [
        "Parametric / self-updatable memory",
        "Contextual / external memory (non-parametric continual learning)",
        "Both are needed; the open question is allocation"
      ]
    },
    {
      "id": "d3",
      "positions": [
        "Episodic memory is the missing piece",
        "Reflective/experiential episodic buffers already deliver much of the value",
        "Both episodic and semantic are facets of a broader memory taxonomy"
      ]
    },
    {
      "id": "d4",
      "positions": [
        "Structure helps multi-hop, associative, and temporal recall",
        "Structure can hurt basic factual recall"
      ]
    }
  ],
