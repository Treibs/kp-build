  "debates": [
    {
      "id": "d1",
      "positions": [
        "Low physiologic doses (~0.3 mg) are optimal; high doses are not better and carry side effects",
        "Pooled effect is modest regardless, with weak dose dependence and small absolute benefit",
        "Guidelines recommend against melatonin for chronic insomnia"
      ]
    },
    {
      "id": "d2",
      "positions": [
        "No significant objective sleep benefit",
        "There is a real mechanistic/subjective signal"
      ]
    },
    {
      "id": "d3",
      "positions": [
        "Useful for global sleep-wake estimates but not diagnostic",
        "Tracker data can drive clinically harmful preoccupation"
      ]
    },
    {
      "id": "d4",
      "positions": [
        "Behavioral therapy (CBT-I) is first-line; drugs are adjunctive",
        "Newer dual orexin antagonists are effective drug options with favorable safety, but do not displace first-line behavioral therapy"
      ]
    },
    {
      "id": "d5",
      "positions": [
        "Insufficient evidence and a real harm signal",
        "Possible benefit in a narrow subgroup"
      ]
    }
  ],
