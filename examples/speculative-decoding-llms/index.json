  "debates": [
    {
      "id": "d1",
      "positions": [
        "A separate or learned draft model is the most effective path to acceleration",
        "Draft models are nontrivial to obtain and can be avoided entirely"
      ]
    },
    {
      "id": "d2",
      "positions": [
        "Speculation helps mainly at small batch sizes and is fragile under high throughput",
        "Speculation can accelerate even high-throughput regimes for moderate-to-long sequences"
      ]
    }
  ],
