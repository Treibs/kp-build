  "debates": [
    {
      "id": "d1",
      "positions": [
        "Scaffolding/agency matters: purpose-built interfaces and autonomous loops drive the gains.",
        "Agency is overrated: a simple localize-repair-validate pipeline matches or beats complex agents at much lower cost."
      ]
    },
    {
      "id": "d2",
      "positions": [
        "Scores are inflated by contamination/memorization and poor generalization.",
        "The benchmark measures a real, hard capability that is genuinely improving."
      ]
    },
    {
      "id": "d3",
      "positions": [
        "Inference-time scaffolding, action design, and decomposition.",
        "Training and RL on real software evolution / executable environments."
      ]
    },
    {
      "id": "d4",
      "positions": [
        "Whole-repo comprehension via graphs/KG/MCTS pays off for navigation and localization.",
        "Targeted, structure-aware retrieval (AST search + spectrum FL) is sufficient and far cheaper."
      ]
    }
  ],
