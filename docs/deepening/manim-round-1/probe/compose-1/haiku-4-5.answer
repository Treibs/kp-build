```python
from manim import *

class StaggeredDotReveal(Scene):
    def construct(self):
        dots = VGroup(*[Circle(radius=0.15) for _ in range(5)])
        dots.arrange(RIGHT, buff=0.5)
        
        self.play(AnimationGroup(
            *[FadeIn(dot, run_time=1) for dot in dots],
            lag_ratio=0.5
        ))
```
