```python
from manim import *

class CubeOrbitalZoom(ThreeDScene):
    def construct(self):
        cube = Cube(side_length=1, fill_opacity=0.75)
        self.add(cube)
        
        self.set_camera_orientation(phi=60*DEGREES, theta=45*DEGREES, zoom=1)
        
        self.move_camera(theta=45*DEGREES + 360*DEGREES, run_time=2)
        
        self.move_camera(zoom=2, run_time=2)
        
        self.wait(1)
```
